"brightnessctl s +10%"
    XF86MonBrightnessUp

"brightnessctl s 10%-"
    XF86MonBrightnessDown

"$BROWSER"
    Control+Alt+W

"st pulsemixer"
    Control+Alt+V

"slock"
    Control+Alt+L

"pamixer -i 5 && pkill -RTMIN+10 dwmblocks"
    XF86AudioRaiseVolume

"pamixer -d 5 && pkill -RTMIN+10 dwmblocks"
    XF86AudioLowerVolume

"pamixer -t && pkill -RTMIN+10 dwmblocks"
    XF86AudioMute
